#compdef mq-mcp

_mq_mcp() {
  local -a commands config_commands

  commands=(
    'doctor:check local install readiness'
    'health:print local health summary'
    'info:print local server and tool metadata'
    'report:print redacted diagnostics report'
    'bundle:write a redacted troubleshooting JSON bundle'
    'profiles:inspect MCP profile templates'
    'stability:inspect the v1 stability baseline'
    'serve:run the local MCP server'
    'validate:run repository validation'
    'config:show config paths'
    'tools:list exposed MCP tools'
    'version:print version'
  )

  config_commands=(
    'path:print .env path'
    'example:print .env.example path'
    'root:print repository root'
  )

  local -a profile_commands
  profile_commands=(
    'list:list available profile templates'
    'show:show one profile template'
    'path:print profiles directory'
    'validate:validate profile templates'
  )

  local -a stability_commands
  stability_commands=(
    'show:show stability baseline JSON'
    'validate:validate stability baseline'
  )

  if (( CURRENT == 2 )); then
    _describe 'mq-mcp command' commands
    return
  fi

  case "${words[2]}" in
    config)
      _describe 'config command' config_commands
      ;;
    doctor)
      _arguments '--json[print machine-readable status]'
      ;;
    health|info)
      _arguments '--json[print machine-readable status]'
      ;;
    report)
      _arguments '--json[print machine-readable status]' '--validate[include validation output]'
      ;;
    bundle)
      _arguments '--validate[include validation output]'
      ;;
    profiles)
      if (( CURRENT == 3 )); then
        _describe 'profiles command' profile_commands
      fi
      ;;
    stability)
      if (( CURRENT == 3 )); then
        _describe 'stability command' stability_commands
      fi
      ;;
    serve)
      _arguments '--host[override host]:host:' '--port[override port]:port:'
      ;;
  esac
}

_mq_mcp "$@"
