{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcamner.github.io/mq-mcp/schemas/feedback-signal.v1.schema.json",
  "title": "MQ Feedback Signal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "producer",
    "repo",
    "feedback_type",
    "target",
    "signal",
    "summary",
    "evidence",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "const": "feedback-signal.v1"
    },
    "producer": {
      "const": "mq-mcp"
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "feedback_type": {
      "type": "string",
      "enum": [
        "recommendation_quality",
        "review_pattern_reuse",
        "promotion_candidate"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "signal": {
      "type": "string",
      "enum": [
        "positive",
        "neutral",
        "negative"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  }
}
