{
  "schema_version": "mq-mcp.profile.v1",
  "name": "claude-desktop",
  "title": "Claude Desktop MCP server",
  "summary": "Claude Desktop mcpServers entry for a local mq-mcp server.",
  "client": "claude-desktop",
  "command": "uv",
  "args": ["--directory", "{{MQ_MCP_APP_DIR}}", "run", "mcp", "run", "server.py"],
  "env": {
    "MQ_MCP_ALLOWED_PATHS": "{{MQ_MCP_REPO_ROOT}}",
    "MQ_MCP_LOCAL_REPOS": "{{MQ_MCP_REPO_ROOT}},{{MQ_HAL_REPO}},{{REPO_SIGNAL_REPO}}"
  },
  "mcpServers": {
    "mq-mcp": {
      "command": "uv",
      "args": ["--directory", "{{MQ_MCP_APP_DIR}}", "run", "mcp", "run", "server.py"],
      "env": {
        "MQ_MCP_ALLOWED_PATHS": "{{MQ_MCP_REPO_ROOT}}",
        "MQ_MCP_LOCAL_REPOS": "{{MQ_MCP_REPO_ROOT}},{{MQ_HAL_REPO}},{{REPO_SIGNAL_REPO}}"
      }
    }
  },
  "recommended_tools": [
    "read_repo_file",
    "list_repo_files",
    "search_repo",
    "tool_safety_report",
    "repo_signal_analyze",
    "hal_repo_report"
  ],
  "safety_notes": [
    "Use absolute local paths when copying this into claude_desktop_config.json.",
    "Start from read-only.json if Claude Desktop does not need macOS actions."
  ]
}
