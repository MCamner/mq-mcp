OPENAI_API_KEY=your_api_key_here

# Optional: colon-separated absolute paths for analyze_guitar_pro, open_in_app, edit_image.
# Without this set, those tools only work on files inside the repo.
# Example:
# MQ_MCP_ALLOWED_PATHS="/Users/mansys/Music:/Users/mansys/Pictures:/Users/mansys/Desktop"
MQ_MCP_ALLOWED_PATHS=""

# Optional: comma-separated absolute paths to local repos for list_local_repos,
# open_repo_terminal, repo_signal_analyze, and repo_signal_checklist.
# Also automatically included in MQ_MCP_ALLOWED_PATHS for file tools.
# bridge.py "gå till <name>" opens Terminal at the matching repo.
# Example:
# MQ_MCP_LOCAL_REPOS="/Users/you/repo-signal,/Users/you/mq-hal,/Users/you/macos-scripts"
MQ_MCP_LOCAL_REPOS=""
